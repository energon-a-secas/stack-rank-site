---
flowchart TB
    User([User]) --> HTML["index.html\nApp shell"]

    subgraph Frontend["Frontend (ES Modules)"]
        HTML --> app["app.js\nEntry point"]
        app --> state["state.js\nShared state + localStorage"]
        app --> render["render.js\nDOM rendering + SortableJS"]
        app --> events["events.js\nUser interactions"]
        app --> data["data.js\nConvex client wrapper"]
        app --> utils["utils.js\nHelpers (toast, clipboard)"]
    end

    subgraph Convex["Convex Backend"]
        data -->|"queries/mutations"| lists["lists.ts\nCRUD operations"]
        lists --> DB[("Database\nlists table")]
    end

    state <-->|"storage-key: stack-rank-state"| Storage[("localStorage\nCache + offline")]
    User -->|"edits at /:listId"| HTML
    User -->|"shares URL"| Clipboard[("Clipboard\nURL sharing")]
